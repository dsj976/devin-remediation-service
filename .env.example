# Required: Devin API token (https://app.devin.ai/settings/api)
DEVIN_API_TOKEN=your-devin-api-token

# Required: GitHub personal access token (needs repo scope for commenting on issues)
GITHUB_TOKEN=your-github-token

# Target repository (owner/repo format)
TARGET_REPO=dsj976/superset

# Devin organization ID (find at https://app.devin.ai/settings)
DEVIN_ORG_ID=your-org-id

# Issue label that triggers remediation
TRIGGER_LABEL=remediation

# Polling interval in seconds for checking Devin session status
POLL_INTERVAL=30

# Scan interval in minutes for checking new issues (0 = disabled)
SCAN_INTERVAL_MINUTES=5
